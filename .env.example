# Copy to .env and fill in (do NOT commit the real .env).

# ---- LLM (optional) ----
# Without a key -> the system uses the static recommendation table (still fully functional).
ANTHROPIC_API_KEY=
ANOMALY_MODEL=claude-haiku-4-5-20251001   # or claude-opus-4-8 for deeper analysis

# ---- Email (optional, only with --email) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password      # https://myaccount.google.com/apppasswords
EMAIL_FROM=your_gmail@gmail.com
EMAIL_TO=bon@thinksmartinsurance.com
